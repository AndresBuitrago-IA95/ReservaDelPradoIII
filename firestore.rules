rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for entrepreneurship
    function isValidEntrepreneurship(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 2000 &&
             data.whatsapp is string && data.whatsapp.size() >= 7 && data.whatsapp.size() <= 20 &&
             data.residentName is string && data.residentName.size() > 0 &&
             data.unitNumber is string && data.unitNumber.size() > 0 &&
             data.category is string &&
             (data.instagram == null || data.instagram is string) &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.token.email == 'andrezbuitrago82@gmail.com' && request.auth.uid == userId;
    }

    match /entrepreneurships/{id} {
      allow get: if true;
      allow list: if resource.data.status == 'approved' || isAdmin();
      
      allow create: if isValidId(id) && 
                      isValidEntrepreneurship(request.resource.data) &&
                      request.resource.data.status == 'pending' &&
                      request.resource.data.createdAt == request.time &&
                      request.resource.data.updatedAt == request.time;
      
      allow update: if isAdmin() && 
                      isValidEntrepreneurship(request.resource.data) &&
                      request.resource.data.updatedAt == request.time;
      
      allow delete: if isAdmin();
    }

    match /configs/main {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
